{
  "name": "what-new-pkg",
  "version": "0.2.2",
  "description": "Compare npm, pnpm, or Yarn Classic lockfiles against git HEAD and report newly introduced dependencies with introducer attribution.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "what-new-pkg": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "demo": "npm run build && node dist/cli.js demo",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "security",
    "supply-chain",
    "npm",
    "audit",
    "lockfile",
    "packages",
    "integrity",
    "compare",
    "yarn"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mayukh-dsc/what-new-pkg.git"
  },
  "bugs": {
    "url": "https://github.com/mayukh-dsc/what-new-pkg/issues"
  },
  "homepage": "https://github.com/mayukh-dsc/what-new-pkg#readme",
  "dependencies": {
    "yaml": "^2.6.0"
  },
  "peerDependencies": {
    "@yarnpkg/lockfile": "^1.1.0"
  },
  "peerDependenciesMeta": {
    "@yarnpkg/lockfile": {
      "optional": true
    }
  },
  "devDependencies": {
    "@yarnpkg/lockfile": "^1.1.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
